      "xl": { "$type": "dimension", "$value": "12px" },
      "2xl": { "$type": "dimension", "$value": "16px" },
      "full": { "$type": "dimension", "$value": "999px" }
    },
    "motion": {
      "instant": { "$type": "duration", "$value": "0ms" },
      "fastest": { "$type": "duration", "$value": "80ms" },
      "fast": { "$type": "duration", "$value": "120ms" },
      "quick": { "$type": "duration", "$value": "80ms" },
      "base": { "$type": "duration", "$value": "180ms" },
      "standard": { "$type": "duration", "$value": "180ms" },
      "enter": { "$type": "duration", "$value": "180ms" },
      "emphasized": { "$type": "duration", "$value": "240ms" },
      "modal": { "$type": "duration", "$value": "240ms" },
      "section": { "$type": "duration", "$value": "280ms" },
      "page": { "$type": "duration", "$value": "280ms" },
      "emphasis": { "$type": "duration", "$value": "240ms" }
    }
  },
  "semantic": {
    "color": {
      "background": {
        "canvas": { "$type": "color", "$value": "{primitive.color.neutral.75}" },
        "canvasSoft": { "$type": "color", "$value": "{primitive.color.neutral.50}" },
        "surface": { "$type": "color", "$value": "{primitive.color.neutral.0}" },
        "surfaceMuted": { "$type": "color", "$value": "{primitive.color.neutral.50}" },
        "surfaceRaised": { "$type": "color", "$value": "{primitive.color.neutral.0}" }
      },
      "text": {
        "default": { "$type": "color", "$value": "{primitive.color.neutral.800}" },
        "strong": { "$type": "color", "$value": "{primitive.color.neutral.900}" },
        "muted": { "$type": "color", "$value": "{primitive.color.neutral.500}" },
        "onAction": { "$type": "color", "$value": "{primitive.color.neutral.0}" }
      },
      "border": {
        "default": { "$type": "color", "$value": "{primitive.color.neutral.150}" },
        "strong": { "$type": "color", "$value": "{primitive.color.neutral.200}" },
        "focus": { "$type": "color", "$value": "{primitive.color.purple.focus}" }
      },
      "action": {
        "primary": { "$type": "color", "$value": "{primitive.color.teal.600}" },
        "primaryHover": { "$type": "color", "$value": "{primitive.color.teal.700}" },
        "primarySoft": { "$type": "color", "$value": "{primitive.color.teal.50}" },
        "secondary": { "$type": "color", "$value": "{primitive.color.blue.600}" },
        "secondarySoft": { "$type": "color", "$value": "{primitive.color.blue.100}" }
      },
      "state": {
        "success": { "$type": "color", "$value": "{primitive.color.green.600}" },
        "warning": { "$type": "color", "$value": "{primitive.color.amber.700}" },
        "danger": { "$type": "color", "$value": "{primitive.color.red.600}" },
        "alert": { "$type": "color", "$value": "{primitive.color.red.700}" },
        "info": { "$type": "color", "$value": "{primitive.color.blue.700}" }
      },
      "chart": {
        "draft": { "$type": "color", "$value": "{primitive.color.chart.indigo}" },
        "ready": { "$type": "color", "$value": "{primitive.color.chart.cyan}" },
        "scheduled": { "$type": "color", "$value": "{primitive.color.chart.amber}" },
        "manual": { "$type": "color", "$value": "{primitive.color.chart.violet}" },
        "published": { "$type": "color", "$value": "{primitive.color.chart.emerald}" },
        "failed": { "$type": "color", "$value": "{primitive.color.chart.rose}" },
        "empty": { "$type": "color", "$value": "{primitive.color.chart.empty}" }
      }
    },
    "density": {
      "compact": { "$type": "dimension", "$value": "36px" },
      "standard": { "$type": "dimension", "$value": "44px" },
      "comfortable": { "$type": "dimension", "$value": "52px" }
    },
    "elevation": {
      "hairline": { "$type": "shadow", "$value": "0 0 0 1px rgb(var(--n-color-border) / 0.95)" },
      "raised": { "$type": "shadow", "$value": "0 8px 18px rgb(var(--n-color-ink) / 0.045)" },
      "overlay": { "$type": "shadow", "$value": "0 16px 38px rgb(var(--n-color-ink) / 0.095)" },
      "modal": { "$type": "shadow", "$value": "0 18px 46px rgb(var(--n-color-ink) / 0.075)" }
    }
  },
  "component": {
    "button": {
      "primary": {
        "bg": { "$type": "color", "$value": "{semantic.color.action.primary}" },
        "bgHover": { "$type": "color", "$value": "{semantic.color.action.primaryHover}" },
        "fg": { "$type": "color", "$value": "{semantic.color.text.onAction}" }
      },
      "height": {
        "compact": { "$type": "dimension", "$value": "{semantic.density.compact}" },
        "standard": { "$type": "dimension", "$value": "{semantic.density.standard}" },
        "comfortable": { "$type": "dimension", "$value": "{semantic.density.comfortable}" }
      }
    },
    "row": {
      "height": {
        "compact": { "$type": "dimension", "$value": "48px" },
        "standard": { "$type": "dimension", "$value": "56px" },
        "comfortable": { "$type": "dimension", "$value": "64px" }
      }
    },
    "surface": {
      "radius": { "$type": "dimension", "$value": "{primitive.radius.xl}" },
      "shadow": { "$type": "shadow", "$value": "{semantic.elevation.raised}" }
    }
  }
}

