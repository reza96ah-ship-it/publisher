  "meta": {
    "name": "nashrino Visual Design Tokens",
    "version": "2026.06.v4.5",
    "phase": "V-4.5 Visual Token Calibration",
    "description": "Warm editorial primitive, semantic, component, density, elevation, Dark Studio, and motion tokens for the Persian-first SocialOps workspace."
  },
