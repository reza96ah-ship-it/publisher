# App
APP_NAME=Rubika Publisher MVP
APP_ENV=local
APP_SECRET_KEY=change_this_secret_key

# Admin seed user
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_this_password

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:3000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Database
POSTGRES_DB=rubika_publisher
POSTGRES_USER=rubika_user
POSTGRES_PASSWORD=change_this_db_password
DATABASE_URL=postgresql+psycopg://rubika_user:change_this_db_password@postgres:5432/rubika_publisher

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Storage
MEDIA_DIR=/app/storage/media

# Rubika placeholder. Real values are entered later in app settings.
RUBIKA_API_BASE_URL=https://botapi.rubika.ir/v3
